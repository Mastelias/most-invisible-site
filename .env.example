# Sanity CMS — fill these in after creating your Sanity project (see README).
# Copy this file to ".env" and add your values. Without them, the site runs
# on the sample content in src/lib/sampleData.ts.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Public site URL (used for canonical + Open Graph tags + sitemap)
PUBLIC_SITE_URL=https://mostinvisible.com

# Contact form — create a free form at formspree.io and paste its ID (the part
# after /f/ in the endpoint). Without it, the form falls back to opening mail.
PUBLIC_FORMSPREE_ID=
